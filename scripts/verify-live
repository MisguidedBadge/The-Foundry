#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MODEL_PATH="${MODEL_PATH:-models/Qwen3.6-35B-A3B/BF16/Qwen3.6-35B-A3B-BF16-00001-of-00002.gguf}"
CTX_SIZE="${CTX_SIZE:-4096}"
MAX_TOKENS="${MAX_TOKENS:-48}"

cd "${ROOT_DIR}"

.venv/bin/python -m llm_gallery.cli verify-runtime \
  --model "${MODEL_PATH}" \
  --ctx-size "${CTX_SIZE}"

.venv/bin/python -m llm_gallery.cli smoke-run \
  --model "${MODEL_PATH}" \
  --ctx-size "${CTX_SIZE}" \
  --max-tokens "${MAX_TOKENS}"
