#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENV_FILE="${ROOT_DIR}/.env.local"

if [[ -f "${ENV_FILE}" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "${ENV_FILE}"
  set +a
fi

MODEL_PATH="${MODEL_PATH:-${LLM_GALLERY_MODEL:-}}"
MODEL_ROOT="${MODEL_ROOT:-${LLM_GALLERY_MODEL_ROOT:-}}"
CTX_SIZE="${CTX_SIZE:-4096}"
MAX_TOKENS="${MAX_TOKENS:-64}"
WEB_RAG_PROMPT="${WEB_RAG_PROMPT:-What is the latest ROCm release?}"

if [[ -z "${LLM_GALLERY_TAVILY_API_KEY:-${TAVILY_API_KEY:-}}" ]]; then
  echo "Missing Tavily API key. Set LLM_GALLERY_TAVILY_API_KEY or TAVILY_API_KEY." >&2
  exit 2
fi

export LLM_GALLERY_WEB_RAG_MODE="${LLM_GALLERY_WEB_RAG_MODE:-auto}"

cd "${ROOT_DIR}"

MODEL_ARGS=()
if [[ -n "${MODEL_PATH}" ]]; then
  MODEL_ARGS+=(--model "${MODEL_PATH}")
elif [[ -n "${MODEL_ROOT}" ]]; then
  MODEL_ARGS+=(--model-root "${MODEL_ROOT}")
fi

.venv/bin/python -m llm_gallery.cli verify-runtime \
  "${MODEL_ARGS[@]}" \
  --ctx-size "${CTX_SIZE}"

TMP_OUTPUT="$(mktemp)"
trap 'rm -f "${TMP_OUTPUT}"' EXIT

.venv/bin/python -m llm_gallery.cli smoke-run \
  "${MODEL_ARGS[@]}" \
  --ctx-size "${CTX_SIZE}" \
  --max-tokens "${MAX_TOKENS}" \
  --prompt "${WEB_RAG_PROMPT}" | tee "${TMP_OUTPUT}"

.venv/bin/python - "${TMP_OUTPUT}" <<'PY'
import json
import sys
from pathlib import Path

payload = json.loads(Path(sys.argv[1]).read_text())
prompts = payload.get("prompts") or []
if not prompts:
    raise SystemExit("verify-web-rag failed: smoke-run returned no prompt results")

first = prompts[0]
status = first.get("web_grounding_status")
citations = first.get("citations") or []
if status != "used":
    raise SystemExit(
        f"verify-web-rag failed: expected web_grounding_status='used', got {status!r}"
    )
if not citations:
    raise SystemExit("verify-web-rag failed: expected non-empty citations")

trusted_suffixes = ("rocm.docs.amd.com", "rocmdocs.amd.com", "amd.com")
relevant = []
for citation in citations:
    url = str(citation.get("url") or "")
    title = str(citation.get("title") or "")
    snippet = str(citation.get("snippet") or "")
    haystack = f"{title} {snippet} {url}".lower()
    if "rocm" not in haystack:
        continue
    if not any(
        url.startswith(f"https://{suffix}/") or f".{suffix}/" in url or f"//{suffix}/" in url
        for suffix in trusted_suffixes
    ):
        continue
    relevant.append(citation)

if not relevant:
    raise SystemExit(
        "verify-web-rag failed: expected at least one relevant AMD/ROCm citation"
    )

print("verify-web-rag passed")
print(f"citations={len(citations)}")
print(f"relevant_citations={len(relevant)}")
PY
